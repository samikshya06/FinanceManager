# Server Configuration
PORT=3000

# Session Configuration
SESSION_SECRET=

# Google OAuth Configuration need to add secrets here

GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# PostgreSQL Database Configuration
DB_USER=postgres
DB_HOST=localhost
DB_NAME=postgres
DB_PASSWORD=
DB_PORT=5432

# AWS Configuration (for SQS integration)
# Set USE_SQS=true to enable async processing with SQS
USE_SQS=false
USE_DYNAMODB=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/your-account-id/your-queue-name

# OpenAI Configuration (for LLM spending insights)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
